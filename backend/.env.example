# Servidor
# Porta em que o backend irá rodar
PORT=3000

# Ambiente da aplicação: "development" ou "production"
# Em "production", a rota /docs (Swagger) é desativada automaticamente
NODE_ENV=development

# Banco de dados (Prisma)
# Formato: mysql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
# Exemplo local: mysql://root:senha123@localhost:3306/fullstack_db
DATABASE_URL=""

# JWT
# Chave secreta usada para assinar os tokens de autenticação
# NUNCA use o valor de exemplo em produção
# Gere um valor seguro com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=""
