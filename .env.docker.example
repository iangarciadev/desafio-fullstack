# Credenciais do banco de dados (usadas pelo docker-compose)
# DB_USER: usuário do MySQL (padrão: root)
DB_USER=root
# DB_ROOT_PASSWORD: senha do usuário root — defina um valor forte em produção
DB_ROOT_PASSWORD=
# DB_NAME: nome do banco de dados que será criado
DB_NAME=fullstack_db

# JWT
# Chave secreta usada para assinar os tokens de autenticação
# NUNCA use um valor fraco em produção
# Gere um valor seguro com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# URL que o NAVEGADOR usa para acessar o backend
# Desenvolvimento local: http://localhost:3000
# Produção: https://api.seudominio.com
VITE_API_URL=http://localhost:3000
